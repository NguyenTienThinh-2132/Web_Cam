@page
@model CamZone.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Hồ Sơ - CamZone";
    var name = User.Identity?.Name;
    var avatarUrl = Model.AvatarUrl;
    var position = "center";
    if (!string.IsNullOrEmpty(avatarUrl) && avatarUrl.Contains("?pos=")) {
        position = avatarUrl.Split("?pos=")[1];
    }
}
<style>
    .manage-container {
        display: flex;
        gap: 32px;
        min-height: 80vh;
    }

    .manage-sidebar {
        flex: 0 0 240px;
        background: transparent;
        border: none;
        padding: 0;
    }

    .manage-sidebar h5 {
        font-family: 'Playfair Display', serif;
        color: var(--color-primary);
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 24px;
        letter-spacing: 0.02em;
    }

    .manage-menu {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .manage-menu-item {
        padding: 12px 16px;
        color: var(--color-muted);
        text-decoration: none;
        border-radius: 4px;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
        cursor: pointer;
        border-left: 4px solid transparent;
        display: flex;
        align-items: center;
        gap: 12px;
        text-transform: uppercase;
    }

    .manage-menu-item:hover {
        background: rgba(61, 43, 31, 0.05);
        color: var(--color-primary);
    }

    .manage-menu-item.active {
        background: #F5F1EE;
        color: var(--color-primary);
        border-left-color: var(--color-accent);
        font-weight: 600;
    }

    .manage-content {
        flex: 1;
        background: #ffffff;
        color: var(--color-on-surface);
        border: 1px solid rgba(61, 43, 31, 0.12);
        border-radius: 12px;
        padding: 40px;
        box-shadow: var(--shadow-sm);
    }

    .manage-content h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--color-primary);
    }

    .manage-content > p {
        color: var(--color-muted);
        font-size: 0.95rem;
        margin-bottom: 32px;
    }

    .profile-section {
        margin-bottom: 40px;
        padding-bottom: 40px;
        border-bottom: 1px solid rgba(61, 43, 31, 0.1);
    }

    .profile-avatar-square {
        width: 150px;
        height: 150px;
        border-radius: 16px;
        background: #F5F1EE;
        border: 1px solid rgba(61, 43, 31, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: var(--color-secondary);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        margin: 0 auto;
    }

    .avatar-upload-btn-square {
        position: absolute;
        bottom: -5px;
        right: -5px;
        width: 36px;
        height: 36px;
        background: #ffffff;
        color: var(--color-primary);
        border: 1px solid rgba(61, 43, 31, 0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 0.95rem;
        box-shadow: var(--shadow-sm);
        z-index: 5;
    }

    .avatar-upload-btn-square:hover {
        background: var(--color-secondary);
        color: var(--color-primary);
        border-color: var(--color-secondary);
        transform: scale(1.05);
    }

    .profile-badge-text {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--color-secondary);
        font-style: italic;
        margin-top: 8px;
    }

    .profile-detail-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .profile-detail-item {
        padding: 20px;
        background: rgba(61, 43, 31, 0.04);
        border-radius: 8px;
        border: 1px solid transparent;
        transition: all 0.3s ease;
        text-align: left;
    }

    .profile-detail-item:hover {
        border-color: rgba(212, 163, 115, 0.3);
        background: rgba(212, 163, 115, 0.06);
        transform: translateY(-2px);
    }

    .profile-detail-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-secondary);
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .profile-detail-value {
        font-size: 1rem;
        color: var(--color-primary);
        font-weight: 600;
        word-break: break-all;
    }

    .btn-edit-header {
        background: var(--color-primary);
        color: #ffffff;
        border: 1px solid var(--color-primary);
        padding: 12px 28px;
        border-radius: 4px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-edit-header:hover {
        background: var(--color-accent);
        border-color: var(--color-accent);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(61, 43, 31, 0.2);
    }

    /* Thẻ đơn hàng - Order Card */
    .order-card {
        background: rgba(61, 43, 31, 0.02) !important;
        border: 1px solid rgba(61, 43, 31, 0.1) !important;
        border-radius: 12px;
        padding: 24px;
        color: var(--color-on-surface);
        transition: all 0.3s ease;
    }

    .order-card:hover {
        border-color: var(--color-secondary) !important;
        background: rgba(212, 163, 115, 0.04) !important;
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }

    @@media (min-width: 992px) {
        .border-start-custom {
            border-left: 1px solid rgba(61, 43, 31, 0.1) !important;
        }
    }

    @@media (max-width: 992px) {
        .manage-container {
            flex-direction: column;
            gap: 24px;
        }

        .manage-sidebar {
            flex: 0 0 auto;
        }

        .profile-detail-grid {
            grid-template-columns: 1fr;
        }

        .profile-section {
            text-align: center;
        }
    }

    .manage-wrapper-container {
        max-width: 1400px;
        margin: 0 auto;
        padding-left: 24px;
        padding-right: 24px;
    }
</style>

<div class="container-fluid py-5 manage-wrapper-container">
    <div class="manage-container">
        <!-- SIDEBAR MENU -->
        <div class="manage-sidebar">
            <h5>Account</h5>
            <div class="manage-menu">
                <a href="/Identity/Account/Manage" id="menu-profile" class="manage-menu-item active" onclick="switchTab('profile'); return false;">
                    <i class="bi bi-person-fill" style="width:18px;"></i>
                    Profile
                </a>
                <a href="/Identity/Account/Manage?tab=orders" id="menu-orders" class="manage-menu-item" onclick="switchTab('orders'); return false;">
                    <i class="bi bi-receipt" style="width:18px;"></i>
                    Đơn hàng của tôi
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="manage-menu-item">
                    <i class="bi bi-key-fill" style="width:18px;"></i>
                    Đổi mật khẩu
                </a>
            </div>
        </div>

        <!-- CONTENT AREA -->
        <div class="manage-content">
            <div id="tab-profile-content">
                <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
                    <div>
                        <h2>Thông Tin Hồ Sơ</h2>
                        <p class="text-muted mb-0" style="font-size: 0.95rem;">Quản lý thông tin cá nhân và tùy chỉnh các cài đặt tài khoản của bạn.</p>
                    </div>
                    <!-- EDIT BUTTON (For View Mode) -->
                    <div id="profile-view-action">
                        <button type="button" class="btn-edit-header" onclick="toggleEdit(true)">
                            <i class="bi bi-pencil-square me-2"></i>Chỉnh Sửa Hồ Sơ
                        </button>
                    </div>
                </div>
                <hr style="border-top: 1px solid rgba(61, 43, 31, 0.1); margin-bottom: 32px;" />

                <form method="post" enctype="multipart/form-data" id="avatar-form" style="display:none;" asp-page-handler="UploadAvatar">
                    @Html.AntiForgeryToken()
                    <input type="file" id="avatar-file" name="AvatarFile" accept="image/*" onchange="document.getElementById('avatar-form').submit()" />
                </form>

                <!-- VIEW MODE (Display) -->
                <div id="profile-view">
                    <div class="row g-4">
                        <!-- Left column: Avatar card -->
                        <div class="col-lg-4 text-center">
                            <div class="avatar-card-wrap">
                                <div style="position:relative; display:inline-block;" class="mb-3">
                                    <div class="profile-avatar-square">
                                        @if (!string.IsNullOrEmpty(Model.AvatarUrl) && Model.AvatarUrl != "/images/default-avatar.png")
                                        {
                                            <img src="@Model.AvatarUrl" alt="Avatar" style="width:100%; height:100%; object-fit:cover; object-position:@position;" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-person"></i>
                                        }
                                    </div>
                                    <button type="button" class="avatar-upload-btn-square" onclick="document.getElementById('avatar-file').click()" title="Thay đổi ảnh đại diện">
                                        <i class="bi bi-camera"></i>
                                    </button>
                                </div>
                                <h4 class="fw-bold mb-1" style="color: var(--color-primary); font-family: 'Playfair Display', serif; font-size: 1.5rem;">
                                    @(Model.FullName ?? name ?? "User")
                                </h4>
                                <div class="profile-badge-text">
                                    Collector Level: Enthusiast
                                </div>
                                <p class="text-muted small mt-2">
                                    Thành viên từ năm 2024
                                </p>
                            </div>
                        </div>

                        <!-- Right column: Details grid -->
                        <div class="col-lg-8">
                            <div class="profile-detail-grid">
                                <div class="profile-detail-item">
                                    <div class="profile-detail-label"><i class="bi bi-envelope me-1"></i> Email</div>
                                    <div class="profile-detail-value">@(Model.Email ?? "N/A")</div>
                                </div>
                                <div class="profile-detail-item">
                                    <div class="profile-detail-label"><i class="bi bi-telephone me-1"></i> Số điện thoại</div>
                                    <div class="profile-detail-value">@(Model.Input?.PhoneNumber ?? "Chưa cập nhật")</div>
                                </div>
                                <div class="profile-detail-item">
                                    <div class="profile-detail-label"><i class="bi bi-geo-alt me-1"></i> Địa chỉ</div>
                                    <div class="profile-detail-value">@(Model.Address ?? "Chưa cập nhật")</div>
                                </div>
                                <div class="profile-detail-item">
                                    <div class="profile-detail-label"><i class="bi bi-calendar-event me-1"></i> Tuổi</div>
                                    <div class="profile-detail-value">@(Model.Age > 0 ? Model.Age.ToString() : "Chưa cập nhật")</div>
                                </div>
                                <div class="profile-detail-item">
                                    <div class="profile-detail-label"><i class="bi bi-gender-ambiguous me-1"></i> Giới tính</div>
                                    <div class="profile-detail-value">@(Model.Input?.GioiTinh ?? "Chưa cập nhật")</div>
                                </div>
                                <div class="profile-detail-item">
                                    <div class="profile-detail-label"><i class="bi bi-briefcase me-1"></i> Nghề nghiệp</div>
                                    <div class="profile-detail-value">@(Model.Input?.NgheNghiep ?? "Chưa cập nhật")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            <!-- EDIT MODE (Form) -->
            <form method="post" id="profile-edit" style="display:none;">
                @Html.AntiForgeryToken()

                <div class="profile-edit-form">
                    <!-- Họ tên -->
                    <div class="edit-form-group">
                        <label class="edit-label" asp-for="Input.FullName">Họ Tên</label>
                        <input asp-for="Input.FullName" class="edit-input" placeholder="Nhập họ và tên" />
                    </div>

                    <!-- Địa chỉ -->
                    <div class="edit-form-group">
                        <label class="edit-label" asp-for="Input.Address">Địa Chỉ</label>
                        <input asp-for="Input.Address" class="edit-input" placeholder="Nhập địa chỉ" />
                    </div>

                    <!-- Tuổi -->
                    <div class="edit-form-group">
                        <label class="edit-label" asp-for="Input.Age">Tuổi</label>
                        <input asp-for="Input.Age" class="edit-input" type="number" placeholder="Nhập tuổi" />
                    </div>

                    <!-- Giới tính -->
                    <div class="edit-form-group">
                        <label class="edit-label" asp-for="Input.GioiTinh">Giới Tính</label>
                        <select asp-for="Input.GioiTinh" class="edit-select">
                            <option value="">-- Chọn --</option>
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>

                    <!-- Nghề nghiệp -->
                    <div class="edit-form-group">
                        <label class="edit-label" asp-for="Input.NgheNghiep">Nghề Nghiệp</label>
                        <input asp-for="Input.NgheNghiep" class="edit-input" placeholder="Nhập nghề nghiệp (tùy chọn)" />
                    </div>

                    <!-- Số điện thoại -->
                    <div class="edit-form-group">
                        <label class="edit-label" asp-for="Input.PhoneNumber">Số Điện Thoại</label>
                        <input asp-for="Input.PhoneNumber" class="edit-input" placeholder="Nhập số điện thoại" />
                    </div>

                    <!-- Góc hiển thị ảnh đại diện -->
                    <div class="edit-form-group">
                        <label class="edit-label">Góc hiển thị Avatar (Chọn & xem trước)</label>
                        <select name="AvatarPosition" class="edit-select" onchange="changeAvatarPreviewPosition(this.value)">
                            <option value="center" selected="@(position == "center")">Căn giữa (Center)</option>
                            <option value="top" selected="@(position == "top")">Căn trên (Top)</option>
                            <option value="bottom" selected="@(position == "bottom")">Căn dưới (Bottom)</option>
                        </select>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="edit-actions">
                    <button type="submit" class="btn-edit-save">
                        <i class="bi bi-check-circle me-2"></i>Lưu Thay Đổi
                    </button>
                    <button type="button" class="btn-edit-cancel" onclick="toggleEdit(false)">
                        <i class="bi bi-x-circle me-2"></i>Hủy
                    </button>
                </div>
            </form>
            </div>

            <!-- ORDERS HISTORIES (Tab 2) -->
            <div id="tab-orders-content" style="display:none;">
                <div class="orders-banner mb-4" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/background.png') center/cover no-repeat; height: 160px; border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(212, 163, 115, 0.25);">
                    <h2 style="color:#ffffff; font-family:'Playfair Display', serif; font-size:2.2rem; font-weight:700; margin:0; text-shadow: 0 4px 8px rgba(0,0,0,0.6);">Lịch Sử Đơn Hàng</h2>
                </div>

                @if (Model.UserOrders != null && Model.UserOrders.Any())
                {
                    <div class="d-flex flex-column gap-4">
                        @foreach (var item in Model.UserOrders)
                        {
                            <div class="order-card">
                                <!-- Header card -->
                                <div class="d-flex justify-content-between align-items-center mb-3 pb-3" style="border-bottom: 1px solid rgba(212, 163, 115, 0.15);">
                                    <div>
                                        <h6 class="fw-bold m-0" style="color: var(--color-primary); font-family: 'Work Sans', sans-serif; text-transform: uppercase; letter-spacing: 0.05em; font-size:0.9rem;">
                                            ĐƠN HÀNG #ORD-@item.Id.ToString("D5")
                                        </h6>
                                        <small style="color: var(--color-muted);">Ngày đặt: @item.OrderDate.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    <div>
                                        @if (item.Notes == "Đã thanh toán" || item.Notes == "Hoàn thành")
                                        {
                                            <span class="badge" style="background: rgba(40, 167, 69, 0.15); color: #28a745; border: 1px solid rgba(40, 167, 69, 0.3); font-size: 0.75rem; padding: 6px 12px; border-radius: 4px; font-weight: 600;">
                                                <i class="bi bi-check-circle-fill me-1"></i>HOÀN THÀNH
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background: rgba(212, 163, 115, 0.15); color: var(--color-secondary); border: 1px solid rgba(212, 163, 115, 0.3); font-size: 0.75rem; padding: 6px 12px; border-radius: 4px; font-weight: 600;">
                                                <i class="bi bi-truck me-1"></i>ĐANG XỬ LÝ
                                            </span>
                                        }
                                    </div>
                                </div>

                                <!-- Body card -->
                                <div class="row align-items-center g-3">
                                    <!-- Cột trái: sản phẩm -->
                                    <div class="col-lg-8">
                                        <div class="d-flex flex-column gap-3">
                                            @foreach (var detail in item.OrderDetails)
                                            {
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background: rgba(212, 163, 115, 0.1); color: var(--color-secondary); flex-shrink: 0; border: 1px solid rgba(212, 163, 115, 0.15); overflow:hidden;">
                                                        @if (!string.IsNullOrEmpty(detail.Product?.ImageUrl))
                                                        {
                                                            <img src="@detail.Product.ImageUrl" alt="Product" style="width: 100%; height: 100%; object-fit: cover;" />
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-camera" style="font-size: 1.2rem;"></i>
                                                        }
                                                    </div>
                                                    <div>
                                                        <h6 class="fw-semibold m-0" style="font-size: 0.95rem; color: var(--color-primary);">@detail.Product?.Name</h6>
                                                        <small style="color: var(--color-muted);">Số lượng: @detail.Quantity × @detail.Price.ToString("#,##0")₫</small>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>

                                    <!-- Cột phải: Tổng tiền & Action -->
                                    <div class="col-lg-4 text-lg-end border-start-custom" style="padding-left: 20px;">
                                        <div class="pe-2">
                                            <small style="color: var(--color-muted); display: block; margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.75rem;">TỔNG CỘNG</small>
                                            <h4 class="fw-bold" style="color: var(--color-accent); font-family: 'Playfair Display', serif; margin-bottom: 16px;">
                                                @item.TotalPrice.ToString("#,##0")₫
                                            </h4>
                                            <a href="/OrderCustomer/Details/@item.Id" class="btn btn-outline-hl btn-sm py-2 px-3" style="font-size: 0.75rem; letter-spacing: 0.05em; border: 1px solid var(--color-primary); color: var(--color-primary); background:transparent;">
                                                XEM CHI TIẾT
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5" style="background: var(--color-surface-low); border-radius:12px; border:1px solid rgba(212,163,115,0.15);">
                        <div style="font-size: 4rem; margin-bottom: 16px;">📦</div>
                        <h4 style="color: var(--color-primary);">Chưa có đơn hàng nào</h4>
                        <p style="color: var(--color-muted);">Bạn chưa thực hiện bất kỳ giao dịch mua sắm nào tại CamZone.</p>
                        <a href="/SanPham" class="btn btn-primary-hl mt-3">
                            <i class="bi bi-shop me-2"></i>Mua sắm ngay
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .profile-edit-form {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 32px;
    }

    .edit-form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .profile-edit-form .edit-form-group:last-child {
        grid-column: 1 / -1;
    }

    .edit-label {
        font-family: 'Work Sans', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-secondary);
    }

    .edit-input,
    .edit-select {
        background: #ffffff;
        border: 1px solid rgba(61, 43, 31, 0.15);
        color: var(--color-primary);
        padding: 12px 16px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.95rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .edit-input::placeholder {
        color: var(--color-muted);
        opacity: 0.5;
    }

    .edit-input:focus,
    .edit-select:focus {
        outline: none;
        border-color: var(--color-secondary);
        background: rgba(212, 163, 115, 0.04);
        box-shadow: 0 0 8px rgba(212, 163, 115, 0.15);
    }

    .edit-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .btn-edit-save,
    .btn-edit-cancel {
        flex: 1;
        padding: 14px 24px;
        border: none;
        border-radius: 4px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-edit-save {
        background: var(--color-primary);
        color: #ffffff;
    }

    .btn-edit-save:hover {
        background: var(--color-accent);
    }

    .btn-edit-cancel {
        background: rgba(61, 43, 31, 0.05);
        color: var(--color-primary);
        border: 1px solid rgba(61, 43, 31, 0.15);
    }

    .btn-edit-cancel:hover {
        background: rgba(61, 43, 31, 0.1);
    }

    @@media (max-width: 768px) {
        .profile-edit-form {
            grid-template-columns: 1fr;
        }

        .edit-actions {
            flex-direction: column;
        }
    }
</style>

<script>
let originalPosition = '@position';

function changeAvatarPreviewPosition(val) {
    const img = document.querySelector('.profile-avatar img');
    if (img) {
        img.style.objectPosition = val;
    }
}

function toggleEdit(show) {
    const viewMode = document.getElementById('profile-view');
    const editMode = document.getElementById('profile-edit');

    if (show) {
        viewMode.style.display = 'none';
        editMode.style.display = 'block';
    } else {
        viewMode.style.display = 'block';
        editMode.style.display = 'none';
        
        // Hoàn tác xem trước góc hiển thị về ban đầu khi nhấn Hủy
        changeAvatarPreviewPosition(originalPosition);
        const select = document.querySelector('select[name="AvatarPosition"]');
        if (select) {
            select.value = originalPosition;
        }
    }
}

function switchTab(tabName) {
    const profileContent = document.getElementById('tab-profile-content');
    const ordersContent = document.getElementById('tab-orders-content');
    const menuProfile = document.getElementById('menu-profile');
    const menuOrders = document.getElementById('menu-orders');

    if (tabName === 'orders') {
        if (profileContent) profileContent.style.display = 'none';
        if (ordersContent) ordersContent.style.display = 'block';
        if (menuProfile) menuProfile.classList.remove('active');
        if (menuOrders) menuOrders.classList.add('active');
        window.history.pushState(null, null, '?tab=orders');
    } else {
        if (profileContent) profileContent.style.display = 'block';
        if (ordersContent) ordersContent.style.display = 'none';
        if (menuProfile) menuProfile.classList.add('active');
        if (menuOrders) menuOrders.classList.remove('active');
        window.history.pushState(null, null, '?tab=profile');
    }
}

document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const tab = urlParams.get('tab');
    if (tab === 'orders') {
        switchTab('orders');
    } else {
        switchTab('profile');
    }
});
</script>
