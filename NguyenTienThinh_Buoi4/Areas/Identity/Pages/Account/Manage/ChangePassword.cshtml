@page
@model CamZone.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    Layout = "/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Đổi Mật Khẩu - CamZone";
}

<style>
    .manage-container {
        display: flex;
        gap: 32px;
        min-height: 80vh;
    }

    .manage-sidebar {
        flex: 0 0 240px;
        background: transparent;
        border: none;
        padding: 0;
    }

    .manage-sidebar h5 {
        font-family: 'Playfair Display', serif;
        color: var(--color-primary);
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 24px;
        letter-spacing: 0.02em;
    }

    .manage-menu {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .manage-menu-item {
        padding: 12px 16px;
        color: var(--color-muted);
        text-decoration: none;
        border-radius: 4px;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
        cursor: pointer;
        border-left: 4px solid transparent;
        display: flex;
        align-items: center;
        gap: 12px;
        text-transform: uppercase;
    }

    .manage-menu-item:hover {
        background: rgba(61, 43, 31, 0.05);
        color: var(--color-primary);
    }

    .manage-menu-item.active {
        background: #F5F1EE;
        color: var(--color-primary);
        border-left-color: var(--color-accent);
        font-weight: 600;
    }

    .manage-content {
        flex: 1;
        background: #ffffff;
        color: var(--color-on-surface);
        border: 1px solid rgba(61, 43, 31, 0.12);
        border-radius: 12px;
        padding: 40px;
        box-shadow: var(--shadow-sm);
    }

    .manage-content h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: var(--color-primary);
    }

    .manage-content > p {
        color: var(--color-muted);
        font-size: 0.95rem;
        margin-bottom: 32px;
    }

    .password-form {
        max-width: 600px;
    }

    .password-form-group {
        margin-bottom: 24px;
    }

    .password-label {
        display: block;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-secondary);
        margin-bottom: 8px;
    }

    .password-input {
        width: 100%;
        background: #ffffff;
        border: 1px solid rgba(61, 43, 31, 0.15);
        color: var(--color-primary);
        padding: 12px 16px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.95rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .password-input::placeholder {
        color: var(--color-muted);
        opacity: 0.5;
    }

    .password-input:focus {
        outline: none;
        border-color: var(--color-secondary);
        background: rgba(212, 163, 115, 0.04);
        box-shadow: 0 0 8px rgba(212, 163, 115, 0.15);
    }

    .password-actions {
        display: flex;
        gap: 12px;
        margin-top: 40px;
    }

    .btn-submit {
        flex: 1;
        padding: 14px 24px;
        background: var(--color-primary);
        color: #ffffff;
        border: none;
        border-radius: 4px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-submit:hover {
        background: var(--color-accent);
    }

    .btn-cancel {
        flex: 1;
        padding: 14px 24px;
        background: rgba(61, 43, 31, 0.05);
        color: var(--color-primary);
        border: 1px solid rgba(61, 43, 31, 0.15);
        border-radius: 4px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .btn-cancel:hover {
        background: rgba(61, 43, 31, 0.1);
    }

    .validation-summary {
        background: rgba(220, 53, 69, 0.1);
        border: 1px solid rgba(220, 53, 69, 0.3);
        border-radius: 4px;
        padding: 16px;
        margin-bottom: 24px;
        color: #dc3545;
    }

    .validation-summary ul {
        margin: 0;
        padding-left: 20px;
    }

    .validation-error {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 4px;
        display: block;
    }

    .status-message {
        background: rgba(40, 167, 69, 0.15);
        border: 1px solid rgba(40, 167, 69, 0.3);
        border-radius: 4px;
        padding: 16px;
        margin-bottom: 24px;
        color: #28a745;
    }

    @@media (max-width: 768px) {
        .manage-container {
            flex-direction: column;
            gap: 24px;
        }

        .manage-sidebar {
            flex: 0 0 auto;
        }

        .password-actions {
            flex-direction: column;
        }
    }

    .manage-wrapper-container {
        max-width: 1400px;
        margin: 0 auto;
        padding-left: 24px;
        padding-right: 24px;
    }
</style>

<div class="container-fluid py-5 manage-wrapper-container">
    <div class="manage-container">
        <!-- SIDEBAR MENU -->
        <div class="manage-sidebar">
            <h5>Account</h5>
            <div class="manage-menu">
                <a href="/Identity/Account/Manage" id="menu-profile" class="manage-menu-item">
                    <i class="bi bi-person-fill" style="width:18px;"></i>
                    Profile
                </a>
                <a href="/Identity/Account/Manage?tab=orders" id="menu-orders" class="manage-menu-item">
                    <i class="bi bi-receipt" style="width:18px;"></i>
                    Đơn hàng của tôi
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="manage-menu-item active">
                    <i class="bi bi-key-fill" style="width:18px;"></i>
                    Đổi mật khẩu
                </a>
            </div>
        </div>

        <!-- CONTENT AREA -->
        <div class="manage-content">
            <h2>Đổi Mật Khẩu</h2>
            <p>Cập nhật mật khẩu của tài khoản CamZone để bảo vệ tài khoản của bạn.</p>

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="status-message">
                    <i class="bi bi-check-circle me-2"></i>@Model.StatusMessage
                </div>
            }

            <form method="post" class="password-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>

                <!-- Mật khẩu hiện tại -->
                <div class="password-form-group">
                    <label class="password-label" asp-for="Input.OldPassword">Mật Khẩu Hiện Tại</label>
                    <input asp-for="Input.OldPassword" class="password-input" type="password" placeholder="Nhập mật khẩu hiện tại" />
                    <span asp-validation-for="Input.OldPassword" class="validation-error"></span>
                </div>

                <!-- Mật khẩu mới -->
                <div class="password-form-group">
                    <label class="password-label" asp-for="Input.NewPassword">Mật Khẩu Mới</label>
                    <input asp-for="Input.NewPassword" class="password-input" type="password" placeholder="Nhập mật khẩu mới (tối thiểu 6 ký tự)" />
                    <span asp-validation-for="Input.NewPassword" class="validation-error"></span>
                </div>

                <!-- Xác nhận mật khẩu -->
                <div class="password-form-group">
                    <label class="password-label" asp-for="Input.ConfirmPassword">Xác Nhận Mật Khẩu</label>
                    <input asp-for="Input.ConfirmPassword" class="password-input" type="password" placeholder="Xác nhận mật khẩu mới" />
                    <span asp-validation-for="Input.ConfirmPassword" class="validation-error"></span>
                </div>

                <!-- Action Buttons -->
                <div class="password-actions">
                    <button type="submit" class="btn-submit">
                        <i class="bi bi-check-circle me-2"></i>Lưu Thay Đổi
                    </button>
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn-cancel">
                        <i class="bi bi-x-circle me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
