@model CamZone.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
    var imageList = Model.ImageUrls?.Take(3).ToList() ?? new List<string>();
}

<!-- Page header -->
<div class="bg-danger bg-opacity-10 border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Sản phẩm</a></li>
                <li class="breadcrumb-item active text-danger">Xóa sản phẩm</li>
            </ol>
        </nav>
        <h2 class="fw-bold mb-0 text-danger">
            <i class="bi bi-trash me-2"></i>Xác nhận xóa sản phẩm
        </h2>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Warning -->
            <div class="alert alert-danger d-flex align-items-start gap-3 mb-4 rounded-3 border-danger">
                <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
                <div>
                    <strong>Cảnh báo!</strong> Bạn sắp xóa sản phẩm này vĩnh viễn.
                    Hành động này <strong>không thể hoàn tác</strong>. Vui lòng kiểm tra kỹ trước khi xác nhận.
                </div>
            </div>

            <!-- Product preview card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="fw-semibold mb-0 text-muted"><i class="bi bi-box-seam me-2"></i>Sản phẩm sẽ bị xóa</h6>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4 align-items-center">
                        <!-- Image -->
                        <div class="col-md-4">
                            <div class="rounded-3 overflow-hidden border bg-light" style="aspect-ratio:1;">
                                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                                {
                                    <img src="@Model.ImageUrl" class="w-100 h-100" style="object-fit:cover;" alt="@Model.Name" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                                        <i class="bi bi-image fs-1 opacity-25"></i>
                                    </div>
                                }
                            </div>
                            @if (imageList.Any())
                            {
                                <div class="d-flex gap-1 mt-2">
                                    @foreach (var img in imageList)
                                    {
                                        <img src="@img" class="rounded-2 border"
                                             style="width:44px;height:44px;object-fit:cover;" alt="" />
                                    }
                                </div>
                            }
                        </div>

                        <!-- Info -->
                        <div class="col-md-8">
                            <h4 class="fw-bold mb-2">@Model.Name</h4>
                            <div class="price-tag fs-4 fw-bold mb-3">
                                @Model.Price.ToString("N0")₫
                            </div>
                            <table class="table table-sm table-borderless text-muted small mb-0">
                                <tr>
                                    <td class="fw-semibold ps-0" style="width:100px;">ID:</td>
                                    <td>#@Model.Id</td>
                                </tr>
                                @if (Model.Category != null)
                                {
                                    <tr>
                                        <td class="fw-semibold ps-0">Danh mục:</td>
                                        <td><span class="badge bg-primary-subtle text-primary">@Model.Category.Name</span></td>
                                    </tr>
                                }
                                <tr>
                                    <td class="fw-semibold ps-0">Mô tả:</td>
                                    <td class="text-truncate" style="max-width:220px;">
                                        @(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Confirm form -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Bạn có chắc chắn muốn xóa <strong>"@Model.Name"</strong> không?
                    </p>
                    <form asp-action="DeleteConfirmed" method="post" class="d-flex gap-3">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg px-5">
                            <i class="bi bi-trash me-2"></i>Xác nhận xóa
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="bi bi-x-circle me-2"></i>Hủy bỏ
                        </a>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
