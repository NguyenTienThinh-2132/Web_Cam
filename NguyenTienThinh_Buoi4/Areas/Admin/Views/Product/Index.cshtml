@model IEnumerable<CamZone.Models.Product>
@{
    ViewData["Title"] = "Danh sách sản phẩm";
    bool canEdit   = User.IsInRole("Admin") || User.IsInRole("Employee");
    bool canDelete = User.IsInRole("Admin");
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a>
                </li>
                <li class="breadcrumb-item active">Sản phẩm</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Tất cả sản phẩm</h2>
                <p class="text-muted small mb-0">
                    <i class="bi bi-box-seam me-1"></i>@Model.Count() sản phẩm
                </p>
            </div>
            @if (canEdit)
            {
                <a asp-action="Add" class="btn btn-primary px-4">
                    <i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm
                </a>
            }
        </div>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Any())
    {
        <div class="text-center py-5 my-3">
            <div style="font-size:5rem;">📦</div>
            <h4 class="fw-bold mt-3 mb-2">Chưa có sản phẩm nào</h4>
            <p class="text-muted mb-4">Bắt đầu bằng cách thêm sản phẩm đầu tiên của bạn.</p>
            @if (canEdit)
            {
                <a asp-action="Add" class="btn btn-primary px-4">
                    <i class="bi bi-plus-circle me-2"></i>Thêm sản phẩm ngay
                </a>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                var thumbList = product.Images?
                    .Select(i => i.Url)
                    .Where(url => !string.IsNullOrWhiteSpace(url))
                    .Take(3)
                    .ToList() ?? new List<string>();

                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="card product-card h-100 border-0 shadow-sm">
                        <!-- Image -->
                        <div class="position-relative product-img-wrap">
                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" class="card-img-top product-img" alt="@product.Name" />
                            }
                            else
                            {
                                <div class="product-img d-flex align-items-center justify-content-center bg-light text-muted">
                                    <i class="bi bi-image fs-1 opacity-25"></i>
                                </div>
                            }

                            @if (product.Category != null)
                            {
                                <span class="badge bg-primary position-absolute top-0 start-0 m-2">@product.Category.Name</span>
                            }

                            <!-- Hover quick actions -->
                            <div class="product-hover-actions">
                                <a asp-action="Display" asp-route-id="@product.Id"
                                   class="btn btn-light btn-sm rounded-circle shadow-sm" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (canEdit)
                                {
                                    <a asp-action="Update" asp-route-id="@product.Id"
                                       class="btn btn-light btn-sm rounded-circle shadow-sm" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                            </div>
                        </div>

                        <div class="card-body d-flex flex-column p-3">
                            <h6 class="card-title fw-semibold mb-1 product-title" title="@product.Name">@product.Name</h6>

                            @if (product.Category != null)
                            {
                                <small class="text-muted mb-1">@product.Category.Name</small>
                            }

                            <p class="text-muted small product-desc mb-2">@product.Description</p>

                            @if (thumbList.Any())
                            {
                                <div class="d-flex gap-1 mb-2">
                                    @foreach (var img in thumbList)
                                    {
                                        <img src="@img" class="rounded"
                                             style="width:36px;height:36px;object-fit:cover;border:1px solid #e2e8f0;" alt="" />
                                    }
                                </div>
                            }

                            <div class="mt-auto">
                                <div class="price-tag fs-5 mb-3">@product.Price.ToString("N0")<span class="fs-6">₫</span></div>

                                <!-- Add to Cart (AJAX) -->
                                <button class="btn btn-outline-dark w-100 mb-2 btn-add-cart"
                                        data-product-id="@product.Id">
                                    <i class="bi-cart-fill me-1"></i> Add to Cart
                                </button>

                                <!-- Quản lý -->
                                <div class="d-flex gap-2">
                                    <a asp-action="Display" asp-route-id="@product.Id"
                                       class="btn btn-outline-primary btn-sm flex-grow-1">
                                        <i class="bi bi-eye me-1"></i>Chi tiết
                                    </a>
                                    @if (canEdit)
                                    {
                                        <a asp-action="Update" asp-route-id="@product.Id"
                                           class="btn btn-warning btn-sm" title="Sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                    }
                                    @if (canDelete)
                                    {
                                        <a asp-action="Delete" asp-route-id="@product.Id"
                                           class="btn btn-outline-danger btn-sm" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
