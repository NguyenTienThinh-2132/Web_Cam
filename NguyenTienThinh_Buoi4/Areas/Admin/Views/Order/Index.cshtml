@model IEnumerable<CamZone.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a>
                </li>
                <li class="breadcrumb-item active">Đơn hàng</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Quản lý đơn hàng</h2>
                <p class="text-muted small mb-0">
                    <i class="bi bi-receipt me-1"></i>@Model.Count() đơn hàng
                </p>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:4rem;">📋</div>
            <h5 class="fw-bold mt-3 mb-2">Chưa có đơn hàng nào</h5>
            <p class="text-muted">Các đơn hàng từ khách hàng sẽ hiển thị tại đây.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="bg-light">
                                <th class="px-4 py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Mã đơn</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Khách hàng</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Ngày đặt</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Địa chỉ</th>
                                <th class="py-3 text-end text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Tổng tiền</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Ghi chú</th>
                                <th class="py-3 text-center pe-4 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td class="px-4">
                                        <span class="fw-semibold">#@order.Id</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                                                 style="width:36px;height:36px;flex-shrink:0;">
                                                <i class="bi bi-person text-primary small"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold small">@(order.ApplicationUser?.UserName ?? "N/A")</div>
                                                <div class="text-muted" style="font-size:.75rem;">@(order.ApplicationUser?.Email ?? "")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted small">
                                        @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="small" style="max-width:180px;">
                                        <span class="text-truncate d-block" title="@order.ShippingAddress">
                                            @order.ShippingAddress
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <span class="price-tag fw-bold">
                                            @order.TotalPrice.ToString("#,##0")₫
                                        </span>
                                    </td>
                                    <td class="small text-muted" style="max-width:140px;">
                                        <span class="text-truncate d-block" title="@order.Notes">
                                            @(string.IsNullOrWhiteSpace(order.Notes) ? "—" : order.Notes)
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <a asp-action="Details" asp-route-id="@order.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-eye me-1"></i>Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
