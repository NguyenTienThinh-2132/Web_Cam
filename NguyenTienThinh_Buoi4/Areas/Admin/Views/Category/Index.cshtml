@model IEnumerable<CamZone.Models.Category>

@{
    ViewData["Title"] = "Danh mục sản phẩm";
    bool canEdit   = User.IsInRole("Admin") || User.IsInRole("Employee");
    bool canDelete = User.IsInRole("Admin");
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a>
                </li>
                <li class="breadcrumb-item active">Danh mục</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Quản lý danh mục</h2>
                <p class="text-muted small mb-0">
                    <i class="bi bi-tags me-1"></i>@Model.Count() danh mục
                </p>
            </div>
            @if (canEdit)
            {
                <a asp-action="Add" class="btn btn-primary px-4">
                    <i class="bi bi-plus-circle me-2"></i>Thêm danh mục
                </a>
            }
        </div>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:4rem;">🏷️</div>
            <h5 class="fw-bold mt-3 mb-2">Chưa có danh mục nào</h5>
            <p class="text-muted mb-4">Tạo danh mục để phân loại sản phẩm của bạn.</p>
            @if (canEdit)
            {
                <a asp-action="Add" class="btn btn-primary px-4">
                    <i class="bi bi-plus-circle me-2"></i>Thêm danh mục ngay
                </a>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="bg-light">
                                <th class="px-4 py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;width:80px;">#</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Tên danh mục</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase text-center" style="letter-spacing:.05em;">Số SP</th>
                                <th class="py-3 text-muted small fw-semibold text-uppercase text-center pe-4" style="letter-spacing:.05em;width:220px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in Model)
                            {
                                <tr>
                                    <td class="px-4 text-muted">#@category.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-primary bg-opacity-10"
                                                 style="width:40px;height:40px;flex-shrink:0;">
                                                <i class="bi bi-tag text-primary"></i>
                                            </div>
                                            <span class="fw-semibold">@category.Name</span>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-light text-muted border">
                                            @(category.Products?.Count ?? 0)
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Details" asp-route-id="@category.Id"
                                               class="btn btn-outline-primary btn-sm" title="Chi tiết">
                                                <i class="bi bi-eye me-1"></i>Chi tiết
                                            </a>
                                            @if (canEdit)
                                            {
                                                <a asp-action="Update" asp-route-id="@category.Id"
                                                   class="btn btn-warning btn-sm" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                            }
                                            @if (canDelete)
                                            {
                                                <a asp-action="Delete" asp-route-id="@category.Id"
                                                   class="btn btn-outline-danger btn-sm" title="Xóa">
                                                    <i class="bi bi-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
