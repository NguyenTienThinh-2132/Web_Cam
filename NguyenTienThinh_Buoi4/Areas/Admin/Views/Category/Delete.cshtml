@model CamZone.Models.Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<!-- Page header -->
<div class="bg-danger bg-opacity-10 border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-action="Index" class="text-decoration-none">Danh mục</a>
                </li>
                <li class="breadcrumb-item active text-danger">Xóa danh mục</li>
            </ol>
        </nav>
        <h2 class="fw-bold mb-0 text-danger">
            <i class="bi bi-trash me-2"></i>Xác nhận xóa danh mục
        </h2>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="alert alert-danger d-flex align-items-start gap-3 mb-4 rounded-3">
                <i class="bi bi-exclamation-triangle-fill fs-4 flex-shrink-0 mt-1"></i>
                <div>
                    <strong>Cảnh báo!</strong> Hành động này <strong>không thể hoàn tác</strong>.
                    Xóa danh mục cũng có thể ảnh hưởng đến các sản phẩm thuộc danh mục này.
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="fw-semibold mb-0 text-muted">
                        <i class="bi bi-tags me-2"></i>Danh mục sẽ bị xóa
                    </h6>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-3 d-flex align-items-center justify-content-center bg-danger bg-opacity-10"
                             style="width:56px;height:56px;flex-shrink:0;">
                            <i class="bi bi-tag fs-3 text-danger"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-1">@Model.Name</h4>
                            <span class="text-muted small">ID: #@Model.Id</span>
                        </div>
                    </div>
                    @if ((Model.Products?.Count ?? 0) > 0)
                    {
                        <div class="alert alert-warning small mb-0">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            Danh mục này đang có <strong>@Model.Products!.Count sản phẩm</strong>. Xóa danh mục có thể ảnh hưởng đến các sản phẩm đó.
                        </div>
                    }
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <p class="text-muted mb-4">
                        Bạn có chắc chắn muốn xóa danh mục <strong>"@Model.Name"</strong> không?
                    </p>
                    <form asp-action="DeleteConfirmed" method="post" class="d-flex gap-3">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg px-5">
                            <i class="bi bi-trash me-2"></i>Xác nhận xóa
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="bi bi-x-circle me-2"></i>Hủy bỏ
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
