@using Microsoft.AspNetCore.Identity
@{
    //Lấy dữ liệu từ controller truyền qua
    var users = ViewBag.Users; //danh sách user
    var roles = ViewBag.Roles as List<IdentityRole>; //danh sách role để chọn cho user
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0 fs-4">
                <i class="bi bi-people-fill me-2"></i>
                Quản lý quyền User
            </h2>
        </div>

        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    @TempData["Success"]

                    <button type="button" class="btn-close" data-bs-dismiss="alert">
                    </button>
                </div>
            }
            <form asp-action="UpdateRoles" method="post">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>UserName</th>
                                <th>FullName</th>
                                <th>Email</th>
                                <th style="width:250px;">Quyền</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Danh sách user có trong hệ thống -->
                            @foreach (var user in users)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @user.UserName
                                        <input type="hidden" name="userIds" value="@user.UserId" />
                                    </td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        <!-- phát sinh ra combo box quyền cho user chọn -->
                                        <select name="roleIds" class="form-select">
                                            @foreach (var role in roles)
                                            {
                                                if (role.Id == user.RoleId)
                                                {
                                                    <option value="@role.Id" selected> @role.Name </option>
                                                }
                                                else
                                                {
                                                    <option value="@role.Id">@role.Name</option>
                                                }
                                            }
                                        </select>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-1"></i>
                        Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>