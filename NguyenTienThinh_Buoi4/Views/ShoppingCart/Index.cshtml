@model CamZone.Models.ShoppingCart
@{
    ViewData["Title"] = "Giỏ hàng";
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <h2 class="fw-bold mb-1"><i class="bi bi-cart3 me-2"></i>Giỏ hàng của bạn</h2>
        <p class="text-muted small mb-0">@Model.Items.Count sản phẩm trong giỏ</p>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Items.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-cart-x" style="font-size: 5rem; color: var(--color-secondary);"></i>
            </div>
            <h4 class="fw-bold mt-3 mb-2">Giỏ hàng trống</h4>
            <p class="text-muted mb-4">Bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
            <a asp-controller="SanPham" asp-action="Index" class="btn btn-gold px-4">
                <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr class="bg-light">
                                    <th class="px-4 py-3 text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Sản phẩm</th>
                                    <th class="py-3 text-center text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Số lượng</th>
                                    <th class="py-3 text-end text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Đơn giá</th>
                                    <th class="py-3 text-end text-muted small fw-semibold text-uppercase" style="letter-spacing:.05em;">Thành tiền</th>
                                    <th class="py-3 pe-4"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="px-4 fw-semibold">@item.Name</td>
                                        <td class="text-center">
                                            <span class="badge hero-badge px-3 py-2">@item.Quantity</span>
                                        </td>
                                        <td class="text-end text-muted">@item.Price.ToString("#,##0") ₫</td>
                                        <td class="text-end price-tag fw-bold">
                                            @((item.Price * item.Quantity).ToString("#,##0")) ₫
                                        </td>
                                        <td class="text-end pe-4">
                                            <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId"
                                               class="btn btn-outline-danger btn-sm"
                                               title="Xóa khỏi giỏ">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-3">
                    <a asp-controller="SanPham" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
                    </a>
                </div>
            </div>

            <!-- Order summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h6 class="fw-semibold mb-0">Tóm tắt đơn hàng</h6>
                    </div>
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between mb-2 text-muted small">
                            <span>Tạm tính (@Model.Items.Sum(i => i.Quantity) sản phẩm)</span>
                            <span>@Model.Items.Sum(i => i.Price * i.Quantity).ToString("#,##0") ₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 text-muted small">
                            <span>Phí vận chuyển</span>
                            <span class="text-success">Miễn phí</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Tổng cộng</span>
                            <span class="price-tag">
                                @Model.Items.Sum(i => i.Price * i.Quantity).ToString("#,##0") ₫
                            </span>
                        </div>
                        <a asp-action="Checkout" class="btn btn-success w-100 btn-lg">
                            <i class="bi bi-credit-card me-2"></i>Tới trang thanh toán
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
