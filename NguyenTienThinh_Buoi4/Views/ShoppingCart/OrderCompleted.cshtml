@model int
@{
    ViewData["Title"] = "Order Completed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <div style="font-size:5rem;" class="mb-3">🎉</div>
            <h2 class="fw-bold text-success mb-3">Order Completed</h2>
            <p class="text-muted fs-5 mb-4">
                Your order with ID <strong class="text-dark">#@Model</strong> has been placed successfully.
            </p>

            <div class="alert alert-success d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-check-circle-fill fs-5"></i>
                <span>Đơn hàng của bạn đã được ghi nhận. Chúng tôi sẽ liên hệ sớm nhất!</span>
            </div>

            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="SanPham" asp-action="Index" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-bag-heart me-2"></i>Tiếp tục mua sắm
                </a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="bi bi-house me-2"></i>Về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>
