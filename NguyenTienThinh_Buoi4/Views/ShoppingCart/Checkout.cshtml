@model CamZone.Models.Order
@{
    ViewData["Title"] = "Thanh toán";
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-controller="ShoppingCart" asp-action="Index" class="text-decoration-none">Giỏ hàng</a></li>
                <li class="breadcrumb-item active">Thanh toán</li>
            </ol>
        </nav>
        <h2 class="fw-bold mb-0"><i class="bi bi-credit-card text-success me-2"></i>Thanh toán</h2>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom py-3">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-geo-alt text-success me-2"></i>Thông tin giao hàng
                    </h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Checkout" method="post">
                        <div asp-validation-summary="All" class="alert alert-danger small mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="ShippingAddress"
                                   class="form-label fw-semibold small text-uppercase text-muted"
                                   style="letter-spacing:.05em;">
                                Địa chỉ giao hàng <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ShippingAddress" class="form-control form-control-lg"
                                   placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành..." />
                            <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Notes"
                                   class="form-label fw-semibold small text-uppercase text-muted"
                                   style="letter-spacing:.05em;">
                                Ghi chú
                            </label>
                            <textarea asp-for="Notes" class="form-control" rows="3"
                                      placeholder="Ghi chú cho đơn hàng (không bắt buộc)..."></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="bi bi-bag-check me-2"></i>Đặt hàng
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-arrow-left me-2"></i>Quay lại giỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
