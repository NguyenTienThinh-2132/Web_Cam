@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div style="display:flex; align-items:center; gap:16px;">
@if (SignInManager.IsSignedIn(User))
{
    <a id="manage" class="nav-link nav-link-custom" asp-area="Identity" asp-page="/Account/Manage/Index" title="Quản lý tài khoản">
        <i class="bi bi-person-circle me-1"></i>
        @UserManager.GetUserName(User)
    </a>
    <form id="logoutForm" method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" style="margin:0;">
        <button id="logout" type="submit" class="nav-link nav-link-custom" style="background:none; border:none; padding:8px 16px; cursor:pointer;">
            Đăng xuất
        </button>
    </form>
}
else
{
    <a class="nav-link nav-link-custom" id="login" asp-area="Identity" asp-page="/Account/Login">
        <i class="bi bi-box-arrow-in-right me-1"></i>
        Đăng nhập
    </a>
}
</div>
