@{
    ViewData["Title"] = "Giới Thiệu - CamZone";
}

<!-- ===== HERO SECTION ===== -->
<section class="py-5" style="background:var(--color-surface);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h1 class="hero-title fw-bold mb-3">Nâu Thơm Nghệ Thuật Nhiếp Ảnh</h1>
                <p style="font-size:1.1rem; color:var(--color-muted); line-height:1.8;">
                    CamZone là cầu nối giữa các nhiếp ảnh gia yêu thích máy ảnh film cổ điển
                    và những sản phẩm chất lượng cao từ các thương hiệu danh tiếng thế giới.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- ===== OUR MISSION SECTION ===== -->
<section class="py-5" style="background:var(--color-surface-low);">
    <div class="container py-4">
        <div class="row g-5 align-items-center">
            <!-- Left: Images -->
            <div class="col-lg-6">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="card border-0" style="border-radius:12px; overflow:hidden; box-shadow:var(--shadow-md);">
                            <img src="https://images.unsplash.com/photo-1502920917128-1aa500764cbd?auto=format&fit=crop&q=80&w=600" alt="Camera Heritage" class="w-100" style="height:300px; object-fit:cover;">
                            <div class="card-body" style="background:#ffffff;">
                                <h5 class="fw-bold" style="color:var(--color-primary);">Chinh Phục Ánh Sáng</h5>
                                <p class="small mb-0" style="color:var(--color-muted);">Mỗi chiếc máy ảnh là một câu chuyện riêng</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card border-0" style="border-radius:12px; overflow:hidden; box-shadow:var(--shadow-md);">
                            <img src="https://images.unsplash.com/photo-1606986628025-35d57e735ae0?auto=format&fit=crop&q=80&w=600" alt="Camera Craftsmanship" class="w-100" style="height:280px; object-fit:cover;">
                            <div class="card-body" style="background:#ffffff;">
                                <h5 class="fw-bold" style="color:var(--color-primary);">Tinh Thần Thợ Thủ Công</h5>
                                <p class="small mb-0" style="color:var(--color-muted);">Chất lượng từng chi tiết là ưu tiên hàng đầu</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Mission Text -->
            <div class="col-lg-6">
                <h2 class="hero-title fw-bold mb-4" style="font-size:2rem;">Sứ Mệnh Của CamZone</h2>
                <p style="font-size:1.05rem; color:var(--color-muted); line-height:1.8; margin-bottom:24px;">
                    Chúng tôi tin rằng mỗi nhiếp ảnh gia xứng đáng có quyền truy cập vào những công cụ chất lượng cao nhất.
                    Từ những chiếc máy ảnh film cổ điển đến các thiết bị số hiện đại, CamZone cam kết mang đến sản phẩm chính hãng
                    với giá cạnh tranh và dịch vụ hỗ trợ tuyệt vời.
                </p>
                <p style="font-size:1.05rem; color:var(--color-muted); line-height:1.8; margin-bottom:32px;">
                    Với bảo hành 24 tháng, vệ sinh miễn phí trọn đời, và đội ngũ chuyên gia tận tâm,
                    chúng tôi đảm bảo bạn không chỉ mua một sản phẩm, mà là một cộng đồng hỗ trợ.
                </p>
                <a href="/#section-tuvan" class="btn btn-primary-hl btn-lg">
                    <i class="bi bi-chat-dots me-2"></i>Liên Hệ Tư Vấn
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ===== OUR EXPERTS SECTION ===== -->
<section class="py-5" style="background:var(--color-surface);">
    <div class="container py-4">
        <h2 class="text-center fw-bold mb-5" style="font-size:2.2rem;">Đội Ngũ Chuyên Gia</h2>
        <div class="row g-4">
            <!-- Expert 1 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0" style="border-radius:12px; overflow:hidden; box-shadow:var(--shadow-sm);">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=400" alt="Expert 1" class="w-100" style="height:280px; object-fit:cover;">
                    <div class="card-body text-center" style="background:#ffffff; padding:24px;">
                        <h5 class="fw-bold mb-1" style="color:var(--color-primary);">Nguyễn Tiến Thịnh</h5>
                        <p class="small mb-3" style="color:var(--color-secondary); font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Chuyên Gia Máy Ảnh</p>
                        <p class="small mb-0" style="color:var(--color-muted);">
                            10+ năm kinh nghiệm với máy ảnh film và số,
                            sở hữu kiến thức sâu sắc về các dòng sản phẩm hàng đầu thế giới.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Expert 2 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0" style="border-radius:12px; overflow:hidden; box-shadow:var(--shadow-sm);">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=400" alt="Expert 2" class="w-100" style="height:280px; object-fit:cover;">
                    <div class="card-body text-center" style="background:#ffffff; padding:24px;">
                        <h5 class="fw-bold mb-1" style="color:var(--color-primary);">Trần Thanh Tâm</h5>
                        <p class="small mb-3" style="color:var(--color-secondary); font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Kỹ Thuật Viên Bảo Hành</p>
                        <p class="small mb-0" style="color:var(--color-muted);">
                            Chuyên sửa chữa và bảo dưỡng các dòng máy ảnh cao cấp,
                            đảm bảo thiết bị của bạn luôn hoạt động tối ưu.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Expert 3 -->
            <div class="col-md-6 col-lg-4">
                <div class="card border-0" style="border-radius:12px; overflow:hidden; box-shadow:var(--shadow-sm);">
                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?auto=format&fit=crop&q=80&w=400" alt="Expert 3" class="w-100" style="height:280px; object-fit:cover;">
                    <div class="card-body text-center" style="background:#ffffff; padding:24px;">
                        <h5 class="fw-bold mb-1" style="color:var(--color-primary);">Phạm Minh Duyên</h5>
                        <p class="small mb-3" style="color:var(--color-secondary); font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Hỗ Trợ Khách Hàng</p>
                        <p class="small mb-0" style="color:var(--color-muted);">
                            Luôn sẵn sàng giải đáp mọi thắc mắc và cung cấp tư vấn
                            chuyên sâu cho từng khách hàng.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
