@model CamZone.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-action="Index" class="text-decoration-none">Đơn hàng của tôi</a>
                </li>
                <li class="breadcrumb-item active">#@Model.Id</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="fw-bold mb-0">
                <i class="bi bi-receipt text-primary me-2"></i>
                Đơn hàng <span class="text-primary">#@Model.Id</span>
            </h2>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                <i class="bi bi-arrow-left me-1"></i>Đơn hàng của tôi
            </a>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">

        <!-- Thông tin đơn + trạng thái -->
        <div class="col-lg-4">

            <!-- Timeline trạng thái -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-4"><i class="bi bi-truck text-primary me-2"></i>Trạng thái đơn hàng</h6>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="status-dot bg-success rounded-circle" style="width:12px;height:12px;flex-shrink:0;"></div>
                            <div>
                                <div class="fw-semibold small">Đặt hàng thành công</div>
                                <div class="text-muted" style="font-size:.75rem;">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="status-dot bg-primary rounded-circle" style="width:12px;height:12px;flex-shrink:0;"></div>
                            <div>
                                <div class="fw-semibold small">Đang xử lý</div>
                                <div class="text-muted" style="font-size:.75rem;">Đơn hàng đang được chuẩn bị</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="status-dot bg-light border rounded-circle" style="width:12px;height:12px;flex-shrink:0;"></div>
                            <div class="text-muted">
                                <div class="small">Đang giao hàng</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="status-dot bg-light border rounded-circle" style="width:12px;height:12px;flex-shrink:0;"></div>
                            <div class="text-muted">
                                <div class="small">Hoàn thành</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Thông tin đơn hàng -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Thông tin đơn hàng</h6>
                    <table class="table table-borderless table-sm mb-0">
                        <tr>
                            <td class="text-muted small ps-0" style="width:100px;">Mã đơn</td>
                            <td class="fw-semibold">#@Model.Id</td>
                        </tr>
                        <tr>
                            <td class="text-muted small ps-0">Ngày đặt</td>
                            <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        <tr>
                            <td class="text-muted small ps-0">Địa chỉ</td>
                            <td class="small">@Model.ShippingAddress</td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(Model.Notes))
                        {
                            <tr>
                                <td class="text-muted small ps-0">Ghi chú</td>
                                <td class="small">@Model.Notes</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            <!-- Tổng tiền -->
            <div class="card border-0 shadow-sm rounded-4 bg-primary text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">Tổng thanh toán</span>
                        <span class="fw-bold fs-4">@Model.TotalPrice.ToString("#,##0")₫</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom py-3 rounded-top-4">
                    <h6 class="fw-semibold mb-0">
                        <i class="bi bi-box-seam text-primary me-2"></i>
                        Sản phẩm đã đặt (@(Model.OrderDetails?.Count ?? 0) sản phẩm)
                    </h6>
                </div>
                <div class="card-body p-0">
                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        @foreach (var detail in Model.OrderDetails)
                        {
                            <div class="d-flex align-items-center gap-3 p-3 border-bottom">
                                <!-- Product image -->
                                <div class="rounded-3 overflow-hidden bg-light flex-shrink-0"
                                     style="width:72px;height:72px;">
                                    @if (!string.IsNullOrWhiteSpace(detail.Product?.ImageUrl))
                                    {
                                        <img src="@detail.Product.ImageUrl" class="w-100 h-100"
                                             style="object-fit:cover;" alt="@detail.Product?.Name" />
                                    }
                                    else
                                    {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </div>

                                <!-- Product info -->
                                <div class="flex-grow-1">
                                    <div class="fw-semibold">@(detail.Product?.Name ?? "Sản phẩm không tồn tại")</div>
                                    <div class="text-muted small">Đơn giá: @detail.Price.ToString("#,##0")₫</div>
                                </div>

                                <!-- Quantity -->
                                <div class="text-center" style="width:80px;">
                                    <div class="text-muted small">Số lượng</div>
                                    <span class="badge bg-primary-subtle text-primary px-3 py-2 mt-1">x@detail.Quantity</span>
                                </div>

                                <!-- Subtotal -->
                                <div class="text-end" style="width:120px;">
                                    <div class="text-muted small">Thành tiền</div>
                                    <div class="price-tag fw-bold">@((detail.Price * detail.Quantity).ToString("#,##0"))₫</div>
                                </div>
                            </div>
                        }

                        <!-- Total row -->
                        <div class="d-flex justify-content-between align-items-center p-4">
                            <span class="text-muted">Tổng cộng (@Model.OrderDetails.Sum(d => d.Quantity) sản phẩm)</span>
                            <span class="price-tag fw-bold fs-5">@Model.TotalPrice.ToString("#,##0")₫</span>
                        </div>
                    }
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                   class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-bag me-2"></i>Tiếp tục mua sắm
                </a>
            </div>
        </div>
    </div>
</div>
