@model IEnumerable<CamZone.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<!-- Page header -->
<div class="bg-light border-bottom py-4">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Trang chủ</a>
                </li>
                <li class="breadcrumb-item active">Đơn hàng của tôi</li>
            </ol>
        </nav>
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1"><i class="bi bi-bag-heart text-primary me-2"></i>Đơn hàng của tôi</h2>
                <p class="text-muted small mb-0"><i class="bi bi-receipt me-1"></i>@Model.Count() đơn hàng</p>
            </div>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary btn-sm rounded-pill px-3">
                <i class="bi bi-bag me-1"></i>Tiếp tục mua sắm
            </a>
        </div>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:5rem;">🛍️</div>
            <h4 class="fw-bold mt-3 mb-2">Bạn chưa có đơn hàng nào</h4>
            <p class="text-muted mb-4">Hãy khám phá sản phẩm và đặt đơn hàng đầu tiên của bạn!</p>
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-primary px-4">
                <i class="bi bi-bag me-2"></i>Mua ngay
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var order in Model)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <div class="row align-items-center g-3">
                            <!-- Order info -->
                            <div class="col-md-3">
                                <div class="text-muted small mb-1">Mã đơn hàng</div>
                                <div class="fw-bold fs-5">#@order.Id</div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small mb-1">Ngày đặt</div>
                                <div class="fw-semibold">@order.OrderDate.ToString("dd/MM/yyyy")</div>
                                <div class="text-muted small">@order.OrderDate.ToString("HH:mm")</div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small mb-1">Địa chỉ giao hàng</div>
                                <div class="small fw-semibold text-truncate" style="max-width:180px;" title="@order.ShippingAddress">
                                    @order.ShippingAddress
                                </div>
                            </div>
                            <div class="col-md-2">
                                <div class="text-muted small mb-1">Tổng tiền</div>
                                <div class="price-tag fw-bold fs-5">@order.TotalPrice.ToString("#,##0")₫</div>
                            </div>
                            <div class="col-md-1 text-end">
                                <a asp-action="Details" asp-route-id="@order.Id"
                                   class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    <i class="bi bi-eye me-1"></i>Xem
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
